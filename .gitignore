# =============================================================================
# Clann .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Compiled binary and object files
# -----------------------------------------------------------------------------
clann
clann_test
*.o
*.Po
*.0
clann.dSYM/
.deps/

# -----------------------------------------------------------------------------
# Autotools build artifacts (generated by ./configure and make)
# These are regenerated by running ./configure; do not track them.
# -----------------------------------------------------------------------------
autom4te.cache/
config.h
config.log
config.status
stamp-h1
Makefile
config.h~
config.h.in~

# -----------------------------------------------------------------------------
# Editor and OS backup files
# -----------------------------------------------------------------------------
*~
*.orig
.DS_Store
tags
index.html~

# -----------------------------------------------------------------------------
# Clann runtime output files
# These are produced during analysis runs and should not be in version control.
# -----------------------------------------------------------------------------
Heuristic_result.txt
NJ-tree.ph
supertree.ps
trees.ps
top_alltrees.txt
bootstrap.txt
consensus.ph
coding.nex
average_consensus.nex
MRP.tree
histogram.txt
robinson-foulds.txt
yaptp.txt
yaptp.ph
sourcetree_scores.txt
sourcetree_scores_dfit.txt
clann.log
clann.log.*
*.recon
*.recon.dist
*.onetoone
*.strict.onetoone
*.gene.births
*.species.decendents
SPRdistances.txt
prunedtrees.txt
prunedtrees_info.txt
prunedtaxa.txt
*.deletedtax
*.tree
Usertrees_result.txt

# -----------------------------------------------------------------------------
# Test and development data (not for distribution)
# -----------------------------------------------------------------------------
test/
dev_examples/
recon_test.ph
recon_test2.ph
test.ph
prunedtree.ph
all_raxml_bestTrees.txt
prune_test.txt
prune_test.txt_info.txt
prune_test.txt_info.txt.zip
html/*

# -----------------------------------------------------------------------------
# Examples output (generated files inside examples/, not source inputs)
# -----------------------------------------------------------------------------
examples/Heuristic_result.txt
examples/NJ-tree.ph
examples/NJ-tree.ph.txt
examples/supertree.ps
examples/trees.ps
examples/Clann_source_trees.ph
examples/Clann_small_source_trees.ph
examples/sourcetree_scores.txt
examples/sourcetree_scores_dfit.txt
examples/testtree.ph
examples/Usertrees_result.txt
examples/trees_to_redo_pruning.tar.gz
examples/redo_delete/

# -----------------------------------------------------------------------------
# Miscellaneous local scratch files
# -----------------------------------------------------------------------------
l
l.1
l2
t
otu
compile
all_topo.ph
alltrees.ph
mltest_results.txt
examples/top10sups_tutorial_single.ph
examples/test_trees.ph
examples/MDS_scatter_plot.py
examples/spr_matrix.txt
examples/visited_trees.ph
examples/visited_trees_2.ph
Doxyfile
my_reconstructions.nhx
